{
  "expo": {
    "name": "AniSav",
    "slug": "anisav-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "anisav",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#121212",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "xyz.savsis.anisav"
    },
    "android": {
      "package": "xyz.savsis.anisav",
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/adaptive-icon-foreground.png",
        "backgroundImage": "./assets/adaptive-icon-background.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#121212"
        }
      ],
      "expo-video",
      "expo-font"
    ]
  }
}
